{
  "name": "kitty-motion",
  "version": "0.1.0",
  "description": "Motion video and game rendering for the Kitty terminal graphics protocol: diff-skipped frames, worker-offloaded PNG encode, backpressure-aware output, font-independent aspect correction, and optional CRT effects.",
  "type": "module",
  "license": "MIT",
  "engines": { "node": ">=20.0.0" },
  "packageManager": "pnpm@11.10.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc --noEmit && tsup --entry.index=src/index.ts --format esm --dts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test:run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
