{
  "name": "kitty-motion",
  "version": "1.0.0",
  "description": "Render video and games in the terminal. Kitty graphics where supported, colored half-blocks everywhere else.",
  "keywords": [
    "kitty",
    "terminal",
    "graphics",
    "kitty-graphics-protocol",
    "animation",
    "emulator",
    "tui",
    "png"
  ],
  "type": "module",
  "license": "MIT",
  "author": "Derek Petersen <tuxracer@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuxracer/kitty-motion.git"
  },
  "bugs": "https://github.com/tuxracer/kitty-motion/issues",
  "homepage": "https://github.com/tuxracer/kitty-motion#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.10.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": [
    "./dist/encode-worker.js"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --noEmit && tsup --clean --entry.index=src/index.ts --entry.encode-worker=src/kittyEncodeWorker/index.ts --format esm --dts",
    "prepack": "pnpm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test:run",
    "generate:ascii-shapes": "node scripts/generateAsciiShapes/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "^9.39.2",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
